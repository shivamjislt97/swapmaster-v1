# =============================================================================
# SwapMaster V1 - Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# === TELEGRAM ===
BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id

# === MEGA (for downloading user-sent MEGA links) ===
MEGA_EMAIL=your_mega_email@example.com
MEGA_PASSWORD=your_mega_password

# === GDRIVE UPLOAD (rclone) ===
GDRIVE_ENABLED=true
GDRIVE_REMOTE_NAME=gdrive
GDRIVE_FOLDER=gdrive:faceswap_output
RCLONE_BIN=rclone
RCLONE_CONF=/full/absolute/path/to/swapmaster-v1-native/.config/rclone/rclone.conf

# === GPU / EXECUTION ===
EXECUTION_PROVIDER=cuda
GPU_ONLY_MODE=true
OUTPUT_VIDEO_ENCODER=libx264
EXECUTION_THREAD_COUNT=4
THREAD_COUNT=4

# === FACE SWAP MODELS ===
FACE_SWAPPER_MODEL=inswapper_128
FACE_ENHANCER_MODEL=gfpgan_1.4
FACE_ENHANCER_BLEND=80
ENABLE_FACE_ENHANCER=true

# === AUTO SLEEP ===
AUTO_SLEEP_ENABLED=true
AUTO_SLEEP_MINUTES=30
POST_JOB_AUTO_SLEEP_SECONDS=300

# === DASHBOARD ===
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8765

# === CONTENT ANALYSIS ===
BYPASS_CONTENT_ANALYSER=false

# === WATCHDOG TIMEOUTS (seconds) ===
PIPELINE_WATCHDOG_PROCESSING_SEC=600
PIPELINE_WATCHDOG_MERGING_SEC=300
PIPELINE_WATCHDOG_UPLOADING_SEC=300
